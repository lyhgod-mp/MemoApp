<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用户注册"
            android:textSize="24sp"
            android:textColor="#1F4E79"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center" />

        <EditText
            android:id="@+id/reg_account"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="账号（必填）"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_pwd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="密码（必填）"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_confirm_pwd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="确认密码（必填）"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="姓名（必填）"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_sex"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="性别（必填）"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_phone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="电话（必填）"
            android:inputType="phone"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/reg_age"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="年龄（必填）"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="注  册"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F4E79"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="返  回"
            android:textSize="18sp"
            android:textColor="#1F4E79"
            android:background="@drawable/btn_outline_bg" />

    </LinearLayout>
</ScrollView>
