<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="新建备忘录"
        android:textSize="22sp"
        android:textColor="#1F4E79"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center" />

    <EditText
        android:id="@+id/et_record_title"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="请输入标题"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:background="@drawable/edit_bg"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="内容"
            android:textSize="14sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_word_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="字数：0"
            android:textSize="14sp"
            android:textColor="#1F4E79" />
    </LinearLayout>

    <EditText
        android:id="@+id/et_record_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="请输入备忘录内容..."
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:padding="16dp"
        android:background="@drawable/edit_bg" />

    <Button
        android:id="@+id/btn_save_record"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="保  存"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1F4E79"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_back_record"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="返  回"
        android:textSize="18sp"
        android:textColor="#1F4E79"
        android:background="@drawable/btn_outline_bg" />

</LinearLayout>
